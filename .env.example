# ─────────────────────────────────────────────
#  PADOSI  –  Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Google OAuth  (https://console.cloud.google.com/)
# 1. Create a project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 2. Authorised redirect URIs: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# Public URL  (change to your deployed domain in production)
BASE_URL=http://localhost:3000
